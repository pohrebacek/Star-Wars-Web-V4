{block content}
<div>
    <a n:href="Media:add" class="btn btn-light">Add media</a>
</div>

<div n:foreach="$mediaDTOs as $mediaDTO" class="container2">
    <div class="container">
        <div class="imageAYear">
            <img src="{$mediaDTO->imageUrl}" class="image">
            <div>
                <p class="Year">{$mediaDTO->getFormattedYear()}</p>
                <p class="Status">{$mediaDTO->canonStatus->value}</p>
                <a n:href="Media:add" class="btn btn-light">Edit media</a>
                <a n:href="Media:deleteMedia, mediaId => $mediaDTO->id" class="btn btn-light">Delete media</a>
            </div>

        </div>

        <div class="nadpisAText">
            <h1>{$mediaDTO->title}</h1>
            <div class="line"></div>
            <p>{$mediaDTO->description}</p>
            <div class="line2"></div>
            <div class="stav">

            </div>
        </div>
    </div>
</div>